    <string name="ssl_ca_cert_info_message_device_owner">{numberOfCertificates,plural, =1{{orgName}ཁྱེད་ཀྱི་སྒྲིག་ཆས་སྟེང་ལག་ཁྱེར་སྤྲོད་མཁན་ཚན་པས་དབང་སྤྲོད་བྱས་པའི་ལག་ཁྱེར་སྒྲིག་འཇུག་བྱས་ཟིན། དེས་སྒྲིག་ཆས་དྲ་རྒྱའི་བྱ་འགུལ་ལ་ལྟ་ཞིབ་བྱ་ཐུབ་སྟེ། གློག་རྡུལ་སྦྲག་ཡིག ཉེར་སྤྱོད་དང་བདེ་འཇགས་དྲ་ཚིགས་ཚུད་ཡོད།

