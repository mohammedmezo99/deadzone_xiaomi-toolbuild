<?xml version="1.0" encoding="utf-8"?>
<com.android.systemui.newstatusbar.layouts.MiuiNotificationStatusContainer xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@id/system_icon_area"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="wrap_content"
    android:layout_height="match_parent">
    <com.android.systemui.statusbar.phone.userswitcher.StatusBarUserSwitcherContainer
        android:orientation="horizontal"
        android:id="@id/user_switcher_container"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="0dp">
        <ImageView
            android:id="@id/current_user_avatar"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scaleType="centerInside" />
        <TextView
            android:textAppearance="@style/TextAppearance.StatusBar.Clock"
            android:id="@id/current_user_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </com.android.systemui.statusbar.phone.userswitcher.StatusBarUserSwitcherContainer>
    <com.android.systemui.newstatusbar.layouts.MiuiStatusBatteryContainer
        android:orientation="horizontal"
        android:id="@id/system_icons"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.android.systemui.newstatusbar.layouts.MiuiStatusIconContainer
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@id/statusIcons"
            android:clipChildren="false"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
        <com.android.systemui.statusbar.phone.MiuiHomePrivacyView
            android:layout_gravity="center"
            android:id="@id/home_privacy_container"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="wrap_content"
            android:layout_height="match_parent" />
    </com.android.systemui.newstatusbar.layouts.MiuiStatusBatteryContainer>
</com.android.systemui.newstatusbar.layouts.MiuiNotificationStatusContainer>
