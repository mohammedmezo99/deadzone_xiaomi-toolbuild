<?xml version="1.0" encoding="utf-8"?>
<com.android.systemui.controlcenter.shade.ControlCenterHeaderView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:id="@id/control_center_header_view"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="@dimen/new_header_height">
    <include
        android:id="@id/normal_control_center_date_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/normal_control_center_status_bar"
        layout="@layout/control_center_date_view"
        style="@style/TextAppearance.QSControl.DateText" />
    <include
        android:id="@id/normal_control_center_status_bar"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_weight="1.0"
        app:layout_constraintStart_toEndOf="@id/normal_control_center_date_view"
        layout="@layout/control_center_status_bar" />
    <include
        android:id="@id/normal_fake_control_center_status_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_weight="1.0"
        app:layout_constraintStart_toEndOf="@id/normal_control_center_date_view"
        layout="@layout/control_center_fake_status_icons" />
    <include
        android:id="@id/normal_privacy_container"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/header_privacy_container_height"
        app:layout_constraintBottom_toTopOf="@id/normal_control_center_status_bar"
        app:layout_constraintEnd_toEndOf="parent"
        layout="@layout/privacy_container" />
    <include
        android:id="@id/normal_flip_privacy_container"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/header_privacy_container_height"
        app:layout_constraintBottom_toTopOf="@id/normal_control_center_status_bar"
        app:layout_constraintEnd_toEndOf="parent"
        layout="@layout/fake_privacy_container" />
    <include
        android:id="@id/normal_fake_privacy_container"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/header_privacy_container_height"
        app:layout_constraintBottom_toTopOf="@id/normal_control_center_status_bar"
        app:layout_constraintEnd_toEndOf="parent"
        layout="@layout/fake_privacy_container" />
    <com.android.systemui.controlcenter.shade.MiuiCarrierTextLayout
        android:gravity="center|end"
        android:orientation="horizontal"
        android:id="@id/normal_control_center_carrier_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="0dp"
        app:layout_constraintBottom_toTopOf="@id/normal_control_center_status_bar"
        app:layout_constraintEnd_toEndOf="parent" />
</com.android.systemui.controlcenter.shade.ControlCenterHeaderView>
