<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@id/miui_keyguard_clock_extra_info"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.android.keyguard.CarrierText
        android:textSize="@dimen/miui_clock_date_text_size"
        android:textColor="@color/miui_common_unlock_screen_common_text_color_new"
        android:id="@id/unlock_screen_sim_info"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/miui_keyguard_clock_sim_info_margin_top"
        android:maxLines="2"
        android:fontFamily="mipro-regular"
        android:textAlignment="center"
        android:layout_marginStart="@dimen/left_top_clock_date_margin_extra" />
    <TextView
        android:textSize="@dimen/miui_clock_date_text_size"
        android:textColor="@color/miui_common_unlock_screen_common_text_color_new"
        android:gravity="center|start|top"
        android:id="@id/unlock_screen_owner_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/miui_keyguard_clock_extra_info_no_show_sim_margin_top"
        android:maxWidth="300dp"
        android:fontFamily="mipro-regular"
        android:layout_marginStart="@dimen/left_top_clock_date_margin_extra"
        android:layout_marginEnd="15dp" />
    <include
        android:layout_gravity="start"
        android:id="@id/unlock_screen_lock_screen_magazine_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/left_top_clock_date_margin_extra"
        layout="@layout/miui_keyguard_lock_screen_magazine_clock_layout" />
</LinearLayout>
