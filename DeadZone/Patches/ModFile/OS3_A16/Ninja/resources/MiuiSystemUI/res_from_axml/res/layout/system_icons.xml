<?xml version="1.0" encoding="utf-8"?>
<com.android.systemui.newstatusbar.layouts.MiuiStatusBatteryContainer xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:id="@id/system_icons"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.android.systemui.newstatusbar.layouts.MiuiStatusIconContainer
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@id/statusIcons"
        android:clipChildren="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />
    <com.android.systemui.statusbar.phone.MiuiHomePrivacyView
        android:layout_gravity="center"
        android:id="@id/home_privacy_container"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="wrap_content"
        android:layout_height="match_parent" />
    <com.android.systemui.newstatusbar.battery.MiuiBatteryMeterView
        android:layout_gravity="center"
        android:id="@id/battery"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:animateLayoutChanges="true" />
</com.android.systemui.newstatusbar.layouts.MiuiStatusBatteryContainer>
