<?xml version="1.0" encoding="utf-8"?>
<com.android.systemui.qs.MiuiNotificationHeaderView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="bottom"
    android:layout_gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingBottom="@dimen/shade_header_bottom_padding"
    android:clickable="false"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="@dimen/qs_panel_width"
    android:layout_height="@dimen/combined_header_height"
    android:paddingStart="@dimen/ns_notification_header_padding"
    android:paddingEnd="@dimen/ns_notification_header_padding">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@id/notification_header_clock_container"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.android.systemui.statusbar.views.MiuiClock
            android:textAppearance="@style/TextAppearance.NSNotification.Clock"
            android:gravity="center_vertical"
            android:id="@id/horizontal_time"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="@dimen/qs_control_center_horizontal_margin_start"
            app:MiuiClockMode="time_date"
            app:MiuiClockShowDark="false" />
        <com.android.systemui.statusbar.views.MiuiNotificationHeaderClock
            android:textAppearance="@style/TextAppearance.QSControl.Clock"
            android:gravity="center_vertical"
            android:id="@id/big_time"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/shade_header_notification_clock_height"
            android:layout_marginBottom="@dimen/qs_control_header_button_margin_bottom"
            android:layout_weight="0.0"
            android:transformPivotX="0dp"
            android:transformPivotY="0dp"
            app:MiuiClockMode="time"
            app:MiuiClockShowDark="false" />
        <LinearLayout
            android:layout_gravity="center_vertical"
            android:orientation="vertical"
            android:id="@id/weather_container"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/qs_control_header_button_margin_bottom"
            android:layout_weight="1.0">
            <TextView
                android:textAppearance="@style/TextAppearance.QSControl.Date"
                android:ellipsize="marquee"
                android:gravity="center_vertical"
                android:id="@id/weather_city"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:marqueeRepeatLimit="marquee_forever" />
            <TextView
                android:textAppearance="@style/TextAppearance.QSControl.Date"
                android:ellipsize="marquee"
                android:gravity="center_vertical"
                android:id="@id/weather_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:marqueeRepeatLimit="marquee_forever" />
        </LinearLayout>
        <LinearLayout
            android:gravity="end"
            android:id="@id/carrier_container_top"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.0">
            <com.android.systemui.controlcenter.shade.MiuiCarrierTextLayout
                android:gravity="center|end"
                android:orientation="horizontal"
                android:id="@id/normal_notification_center_carrier_view_top"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginEnd="@dimen/qs_control_center_horizontal_margin_start"
                app:MiuiShowHdIcon="false" />
        </LinearLayout>
        <LinearLayout
            android:gravity="bottom|center|end"
            android:layout_gravity="bottom"
            android:id="@id/shortcut_container_top"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.0">
            <ImageView
                android:id="@id/notification_shade_shortcut_top"
                android:visibility="gone"
                android:layout_width="@dimen/qs_control_header_button_size"
                android:layout_height="@dimen/qs_control_header_button_size"
                android:contentDescription="@string/accessibility_settings"
                android:layout_marginEnd="@dimen/qs_control_header_button_margin_start" />
        </LinearLayout>
        <LinearLayout
            android:gravity="end"
            android:orientation="horizontal"
            android:id="@id/privacy_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>
    <com.miui.systemui.controlcenter.widget.ReverseDirectionLinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@id/notification_header_date_container"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="@dimen/qs_control_header_button_size">
        <ImageView
            android:id="@id/notification_shade_shortcut_bottom"
            android:visibility="gone"
            android:layout_width="@dimen/qs_control_header_button_size"
            android:layout_height="@dimen/qs_control_header_button_size"
            android:contentDescription="@string/accessibility_settings"
            android:layout_marginStart="@dimen/qs_control_header_button_margin_start"
            android:accessibilityTraversalAfter="2131428207" />
        <com.miui.systemui.controlcenter.widget.ConfigurationDirectionLinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.0"
            android:layoutDirection="locale">
            <com.android.systemui.statusbar.views.MiuiClock
                android:textAppearance="@style/TextAppearance.QSControl.Date"
                android:layout_gravity="bottom"
                android:id="@id/date_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.05"
                app:MiuiClockMode="date_24"
                app:MiuiClockShowDark="false" />
            <LinearLayout
                android:gravity="bottom"
                android:orientation="horizontal"
                android:id="@id/carrier_container_bottom"
                android:visibility="gone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.0">
                <com.android.systemui.controlcenter.shade.MiuiCarrierTextLayout
                    android:gravity="center|end"
                    android:orientation="horizontal"
                    android:id="@id/normal_notification_center_carrier_view_bottom"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="0dp"
                    app:MiuiShowHdIcon="false" />
            </LinearLayout>
        </com.miui.systemui.controlcenter.widget.ConfigurationDirectionLinearLayout>
    </com.miui.systemui.controlcenter.widget.ReverseDirectionLinearLayout>
</com.android.systemui.qs.MiuiNotificationHeaderView>
