<?xml version="1.0" encoding="utf-8"?>
<com.android.systemui.newstatusbar.MiuiKeyguardStatusBarView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_vertical"
    android:id="@id/keyguard_header"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="@dimen/status_bar_header_height_keyguard"
    android:baselineAligned="false">
    <RelativeLayout
        android:id="@id/keyguard_status_bar_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignParentStart="true">
        <FrameLayout
            android:orientation="horizontal"
            android:id="@id/keyguard_status_bar_left_side"
            android:paddingTop="@dimen/status_bar_padding_top"
            android:paddingBottom="@dimen/status_bar_padding_bottom"
            android:clipChildren="true"
            android:clipToPadding="true"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:paddingEnd="3dp"
            android:layout_alignParentStart="true">
            <com.android.systemui.statusbar.views.LimitedSizeFrameLayout
                android:layout_gravity="center|start"
                android:id="@id/prompt_container"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/status_bar_icon_height"
                app:MiuiMaxWidth="@dimen/status_bar_prompt_max_width" />
            <FrameLayout
                android:id="@id/keyguard_left_frame"
                android:layout_width="wrap_content"
                android:layout_height="match_parent">
                <com.android.systemui.controlcenter.shade.MiuiCarrierTextLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:id="@id/keyguard_carrier_layout"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginStart="@dimen/status_bar_keyguard_carrier_text_margin"
                    app:MiuiShowHdIcon="false" />
                <LinearLayout
                    android:gravity="center_vertical"
                    android:id="@id/ll_alarm_container"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:importantForAccessibility="yes">
                    <ImageView
                        android:id="@id/alarm_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:importantForAccessibility="no" />
                    <Chronometer
                        android:textSize="@dimen/timer_running_status_bar_text_size"
                        android:textColor="@color/alarm_text_normal"
                        android:id="@id/alarm_display"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:importantForAccessibility="no"
                        android:layout_marginStart="@dimen/status_bar_alarm_text_margin"
                        android:fontVariationSettings="'wght' 500" />
                </LinearLayout>
            </FrameLayout>
        </FrameLayout>
        <Space
            android:gravity="center"
            android:id="@id/cutout_space_view"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="match_parent" />
        <LinearLayout
            android:gravity="center|end"
            android:orientation="horizontal"
            android:id="@id/status_icon_area"
            android:paddingTop="@dimen/status_bar_padding_top"
            android:paddingBottom="@dimen/status_bar_padding_bottom"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_alignParentEnd="true">
            <com.android.systemui.statusbar.phone.userswitcher.StatusBarUserSwitcherContainer
                android:orientation="horizontal"
                android:id="@id/user_switcher_container"
                android:visibility="gone"
                android:layout_width="0dp"
                android:layout_height="0dp">
                <ImageView
                    android:id="@id/current_user_avatar"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:scaleType="centerInside" />
                <TextView
                    android:textAppearance="@style/TextAppearance.StatusBar.Clock"
                    android:id="@id/current_user_name"
                    android:layout_width="0dp"
                    android:layout_height="0dp" />
            </com.android.systemui.statusbar.phone.userswitcher.StatusBarUserSwitcherContainer>
            <include
                android:gravity="center|end"
                android:id="@id/system_icons_container"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="@dimen/status_bar_padding_start"
                android:layout_marginStart="@dimen/system_icons_super_container_margin_start"
                layout="@layout/system_icons" />
            <ImageView
                android:layout_gravity="center"
                android:id="@id/multi_user_avatar"
                android:visibility="gone"
                android:layout_width="@dimen/multi_user_avatar_keyguard_size"
                android:layout_height="@dimen/multi_user_avatar_keyguard_size"
                android:scaleType="centerInside" />
        </LinearLayout>
    </RelativeLayout>
    <LinearLayout
        android:gravity="center|start"
        android:orientation="horizontal"
        android:id="@id/privacy_area"
        android:paddingTop="@dimen/status_bar_padding_top"
        android:paddingBottom="@dimen/status_bar_padding_bottom"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_margin="@dimen/status_bar_padding_end"
        android:layout_centerVertical="true"
        android:paddingStart="@dimen/privacy_dot_padding_start"
        android:layout_alignParentEnd="true">
        <LinearLayout
            android:orientation="horizontal"
            android:id="@id/privacy_container"
            android:layout_width="wrap_content"
            android:layout_height="match_parent" />
    </LinearLayout>
</com.android.systemui.newstatusbar.MiuiKeyguardStatusBarView>
