<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">
    <com.android.systemui.newstatusbar.battery.BatteryIconContainer
        android:id="@id/battery_icon_container"
        android:layout_width="wrap_content"
        android:layout_height="match_parent">
        <com.android.systemui.newstatusbar.battery.BatteryMeterIconView
            android:layout_gravity="center_vertical"
            android:id="@id/battery_image"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/status_bar_icon_height" />
        <com.android.systemui.newstatusbar.battery.HollowBatteryMeterIconView
            android:layout_gravity="center_vertical"
            android:id="@id/hollow_battery_image"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/status_bar_icon_height" />
    </com.android.systemui.newstatusbar.battery.BatteryIconContainer>
    <com.android.systemui.newstatusbar.battery.BatteryChargeView
        android:layout_gravity="center"
        android:id="@id/battery_charge_out_image"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="match_parent" />
    <com.android.systemui.newstatusbar.battery.BatteryPercentContainer
        android:layout_gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@id/battery_percentage_container"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:importantForAccessibility="no"
        android:layoutDirection="ltr">
        <com.android.systemui.newstatusbar.battery.PercentOutView
            android:textAppearance="@style/TextAppearance.StatusBar.Battery.Percent"
            android:gravity="center_vertical"
            android:layout_gravity="center_vertical"
            android:id="@id/battery_percentage_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:importantForAccessibility="no" />
        <com.android.systemui.newstatusbar.battery.PercentMarkView
            android:textSize="@dimen/battery_percent_mark_view_text_size"
            android:textStyle="normal"
            android:gravity="center_vertical"
            android:id="@id/battery_percentage_mark_view"
            android:paddingTop="@dimen/battery_percent_mark_view_padding_top"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="@string/battery_meter_percent_sign"
            android:singleLine="true"
            android:importantForAccessibility="no" />
    </com.android.systemui.newstatusbar.battery.BatteryPercentContainer>
</merge>
